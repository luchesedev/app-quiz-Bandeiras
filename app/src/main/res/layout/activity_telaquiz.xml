<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/main"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    tools:context=".Telaquiz">



    <FrameLayout

        android:layout_width="match_parent"

        android:layout_height="match_parent">







        <ImageView

            android:id="@+id/imageView7"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:scaleType="centerCrop"

            app:srcCompat="@drawable/unamed" />



        <TextView

            android:id="@+id/textview3"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_gravity="center_horizontal"

            android:layout_marginTop="110dp"

            android:text="Qual é esta placa?"

            android:textColor="@color/white"

            android:textSize="22sp"

            android:textStyle="bold" />



        <ImageView

            android:id="@+id/imgplaca"

            android:layout_width="250dp"

            android:layout_height="155dp"

            android:layout_gravity="center_vertical"

            android:layout_marginLeft="55dp"

            android:layout_marginBottom="125dp"

            android:scaleType="centerCrop"

            app:srcCompat="@drawable/africadosul" />


        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="80dp"
            android:orientation="vertical">

            <RadioGroup
                android:id="@+id/grupoAlternativas"
                android:layout_width="match_parent"
                android:layout_height="match_parent" >

                <RadioButton
                    android:layout_width="280dp"
                    android:id="@+id/btn1"
                    android:layout_height="50dp"
                    android:button="@null"
                    style="@style/Widget.AppCompat.Button"
                    android:background="@drawable/botao_selecionado"

                    android:textColor="@color/text_selector"
                    android:layout_marginTop="3dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:text="Alternativa A"
                    app:cornerRadius="0px" />

                <RadioButton
                    android:id="@+id/btn2"
                    android:layout_width="280dp"
                    android:layout_height="50dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:button="@null"
                    style="@style/Widget.AppCompat.Button"
                    android:background="@drawable/botao_selecionado"

                    android:layout_marginTop="3dp"
                    android:textColor="@color/text_selector"
                    android:text="Alternativa B"
                    app:cornerRadius="0px" />

                <RadioButton
                    android:id="@+id/btn3"
                    android:layout_width="280dp"
                    android:layout_height="50dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:button="@null"
                    style="@style/Widget.AppCompat.Button"
                    android:background="@drawable/botao_selecionado"

                    android:layout_marginTop="3dp"
                    android:textColor="@color/text_selector"
                    android:text="Alternativa C"
                    app:cornerRadius="0px" />

                <RadioButton
                    android:id="@+id/btn4"
                    android:layout_width="280dp"
                    android:layout_height="50dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:button="@null"
                    style="@style/Widget.AppCompat.Button"
                    android:background="@drawable/botao_selecionado"

                    android:layout_marginTop="3dp"
                    android:textColor="@color/text_selector"
                    android:text="Alternativa D"
                    app:cornerRadius="0px" />
            </RadioGroup>


            <Button
                android:layout_marginTop="3dp"
                android:id="@+id/btnproxima"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:layout_gravity="bottom|center_horizontal"
                android:background="@drawable/borda_historico"
                android:onClick="verificarResposta"
                android:text="próxima pergunta"
                android:textColor="@color/azul"
                app:backgroundTint="@null"
                app:cornerRadius="0px" />
        </LinearLayout>

        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="15dp"
            android:text="Acertos:0"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>