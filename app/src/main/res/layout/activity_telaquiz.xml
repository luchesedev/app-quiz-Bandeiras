<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/main"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    tools:context=".Telaquiz">



    <FrameLayout

        android:layout_width="match_parent"

        android:layout_height="match_parent">







        <ImageView

            android:id="@+id/imageView7"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:scaleType="centerCrop"

            app:srcCompat="@drawable/unamed" />



        <TextView

            android:id="@+id/textview3"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_gravity="center_horizontal"

            android:layout_marginTop="110dp"

            android:text="Qual é esta placa?"

            android:textColor="@color/white"

            android:textSize="22sp"

            android:textStyle="bold" />



        <ImageView

            android:id="@+id/imgplaca"

            android:layout_width="250dp"

            android:layout_height="155dp"

            android:layout_gravity="center_vertical"

            android:layout_marginLeft="55dp"

            android:layout_marginBottom="125dp"

            android:scaleType="centerCrop"

            app:srcCompat="@drawable/africadosul" />



        <Button

            android:id="@+id/btn1"

            android:layout_width="280dp"

            android:layout_height="50dp"

            android:layout_gravity="bottom|center_horizontal"

            android:layout_marginBottom="220dp"

            android:onClick="verificarResposta"

            android:text="Alternativa A"

            app:backgroundTint="#005792"

            app:cornerRadius="0px" />



        <Button

            android:id="@+id/btn2"

            android:layout_width="280dp"

            android:layout_height="50dp"

            android:layout_gravity="bottom|center_horizontal"

            android:layout_marginBottom="170dp"

            android:onClick="verificarResposta"

            android:text="Alternativa B"

            app:backgroundTint="#005792"

            app:cornerRadius="0px" />



        <Button

            android:id="@+id/btn3"

            android:layout_width="280dp"

            android:layout_height="50dp"

            android:layout_gravity="bottom|center_horizontal"

            android:layout_marginBottom="120dp"

            android:onClick="verificarResposta"

            android:text="Alternativa C"

            app:backgroundTint="#005792"

            app:cornerRadius="0px" />



        <Button

            android:id="@+id/btn4"

            android:layout_width="280dp"

            android:layout_height="50dp"

            android:layout_gravity="bottom|center_horizontal"

            android:layout_marginBottom="70dp"

            android:onClick="verificarResposta"

            android:text="Alternativa D"

            app:backgroundTint="#005792"

            app:cornerRadius="0px" />


        <TextView

            android:id="@+id/textView4"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_gravity="bottom|center_horizontal"

            android:layout_marginBottom="10dp"

            android:text="Acertos:0"

            android:textColor="@color/white"

            android:textSize="22sp"
            android:textStyle="bold" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>